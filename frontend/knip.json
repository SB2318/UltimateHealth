{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "App.tsx",
    "index.js",
    "app.json",
    "plugins/**/*.{js,ts}",
    "scripts/**/*.{js,ts}"
  ],
  "project": [
    "App.tsx",
    "index.js",
    "app.json",
    "jest.setup.ts",
    "src/**/*.{ts,tsx,js,jsx}",
    "src/**/*.d.ts",
    "plugins/**/*.{js,ts}",
    "scripts/**/*.{js,ts}"
  ],
  "ignore": [
    "node_modules/**",
    "public/**",
    "web-build/**",
    "**/__mocks__/**",
    "**/__tests__/**",
    "**/*.{spec,test}.{ts,tsx,js,jsx}",
    "**/*.config.{ts,js,mjs,cjs}",
    "tsconfig.json"
  ],
  "ignoreBinaries": [
    "expo",
    "jest",
    "knip",
    "tsc"
  ],
  "paths": {
    "@/*": [
      "./*"
    ]
  },
  "ignoreDependencies": []
}
