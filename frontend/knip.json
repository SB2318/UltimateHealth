{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "App.tsx",
    "index.js",
    "app.json",
    "app.config.js",
    "tamagui.config.ts",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "jest.setup.ts",
    "plugins/**/*.{js,ts}",
    "scripts/**/*.{js,ts}",
    "src/screens/**/*.{ts,tsx,js,jsx}",
    "src/navigations/**/*.{ts,tsx,js,jsx}"
  ],
  "project": [
    "**/*.{ts,tsx,js,jsx,d.ts}"
  ],
  "ignore": [
    "android/**",
    "ios/**",
    "node_modules/**",
    "**/__mocks__/**",
    "**/__tests__/**",
    "**/*.{spec,test}.{ts,tsx,js,jsx}",
    "tsconfig.json",
    ".prettierrc.js"
  ],
  "paths": {
    "@/*": [
      "./*"
    ]
  },
  "ignoreDependencies": [
    "babel-preset-expo",
    "metro-config",
    "react-native-svg-transformer",
    "audio-module"
  ]
}
