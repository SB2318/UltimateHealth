{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    "**/*.config.{ts,js,mjs,cjs}",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "react-native.config.js",
    ".eslintrc.js"
  ],
  "rules": {
    "types": "off",
    "duplicates": "off",
    "exports": "off",
    "unresolved": "warn",
    "files": "off",
    "dependencies": "off",
    "devDependencies": "off",
    "unlisted": "off"
  }
}
