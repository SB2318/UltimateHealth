{
  "extends": "expo/tsconfig.base",

  "compilerOptions": {
    "strict": false,

    "jsx": "react-native",

    "moduleResolution": "bundler",

    "skipLibCheck": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "types": [
      "react",
      "react-native"
    ],

    "paths": {
      "@/*": [
        "./src/*"
      ]
    },

    "ignoreDeprecations": "5.0"
  },

  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],

  "exclude": [
    "node_modules"
  ]
}