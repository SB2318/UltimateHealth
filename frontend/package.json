  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fs",
          "react-native-tts",
          "react-native-version-check",
          "audio-module"
        ],
        "listUnknownPackages": false
      },
      "appConfigFieldsNotSyncedCheck": {
        "exclude": [
          "orientation",
          "icon",
          "scheme",
          "userInterfaceStyle",
          "androidStatusBar",
          "splash",
          "ios",
          "android",
          "plugins"
        ]
      }
    }
  }
